{
  "entities": {
    "products": {
      "title": "Product",
      "description": "Details of products available for preorder.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "availableSizes": { "type": "array" },
        "availableColors": { "type": "array" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "isActive"]
    },
    "settings": {
      "title": "Application Settings",
      "description": "Global settings for the application including stock limits.",
      "type": "object",
      "properties": {
        "stockLimits": {
          "type": "object",
          "properties": {
            "S": { "type": "integer" },
            "M": { "type": "integer" },
            "L": { "type": "integer" },
            "XL": { "type": "integer" },
            "XXL": { "type": "integer" },
            "XXXL": { "type": "integer" }
          }
        }
      },
      "required": ["stockLimits"]
    },
    "Order": {
      "title": "Order",
      "description": "Preorder information for a custom t-shirt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "size": { "type": "string", "enum": ["S", "M", "L", "XL", "XXL", "XXXL"] },
        "color": { "type": "string" },
        "quantity": { "type": "integer" },
        "paymentProofUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "processing", "shipped", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "phone", "address", "size", "color", "quantity", "paymentProofUrl"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "products",
      "description": "Available products for sale."
    },
    "/settings/{settingsId}": {
      "schema": "settings",
      "description": "Global application settings."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of preorders"
    }
  }
}
